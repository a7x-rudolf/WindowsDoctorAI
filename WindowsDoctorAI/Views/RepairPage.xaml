<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsDoctorAI.Views.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WindowsDoctorAI.Converters"
    xmlns:models="using:WindowsDoctorAI.Models"
    NavigationCacheMode="Required">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:CountToVisibilityConverter x:Key="CountToVis" />
        <converters:CountToVisibilityConverter x:Key="CountToInvVis" Invert="True" />
    </Page.Resources>

    <ScrollViewer Padding="32,24" HorizontalScrollBarVisibility="Disabled">
        <Grid HorizontalAlignment="Stretch">
            <StackPanel Spacing="8" HorizontalAlignment="Stretch">

                <TextBlock Text="Repair Actions" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Available fixes for detected issues"
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0,0,0,20" />

                <!-- Empty state -->
                <Border Style="{StaticResource PremiumCardStyle}"
                        Visibility="{x:Bind ViewModel.PendingRepairs.Count, Mode=OneWay, Converter={StaticResource CountToInvVis}}">
                    <StackPanel Spacing="12" Padding="40" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE90F;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="No Repair Actions Available" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,0" />
                        <TextBlock Text="Run a diagnostic scan to detect issues and their repair actions"
                                   Style="{StaticResource PageSubtitleStyle}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Content when has repairs -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.PendingRepairs.Count, Mode=OneWay, Converter={StaticResource CountToVis}}">

                    <!-- Hero header -->
                    <Border CornerRadius="8" Padding="20"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#14005FB8" Offset="0" />
                                <GradientStop Color="#0A4CC2FF" Offset="1" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE90F;" FontSize="16"
                                              Foreground="{StaticResource BrandAccentBrush}" />
                                    <TextBlock FontWeight="SemiBold" FontSize="14">
                                        <Run Text="{x:Bind ViewModel.PendingRepairs.Count, Mode=OneWay}" />
                                        <Run Text="repair actions available" />
                                    </TextBlock>
                                </StackPanel>
                                <TextBlock FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="Low-risk automated fixes can be applied safely without additional confirmation" />
                            </StackPanel>

                            <Button Grid.Column="1"
                                    Style="{StaticResource PremiumPrimaryButtonStyle}"
                                    Click="FixAll_Click">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE945;" FontSize="14" />
                                    <TextBlock Text="Fix All Safe Issues" />
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Warning bar -->
                    <InfoBar IsOpen="True" IsClosable="False" Severity="Warning"
                             Title="Review Before Executing"
                             Message="Some repairs require administrator privileges, restart services, or a system reboot. Review each action carefully before running." />

                    <!-- Repair Grid (Responsive) -->
                    <ItemsRepeater ItemsSource="{x:Bind ViewModel.PendingRepairs, Mode=OneWay}">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="420" MinItemHeight="160"
                                               MinColumnSpacing="10" MinRowSpacing="10" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:RepairAction">
                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="16">
                                    <StackPanel Spacing="10">
                                        <!-- Header: Icon + Execute button -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="44" Height="44" CornerRadius="8"
                                                    Background="{StaticResource StatusInfoBgBrush}"
                                                    Margin="0,0,12,0">
                                                <FontIcon Glyph="&#xE90F;" FontSize="18"
                                                          Foreground="{StaticResource StatusInfoBrush}" />
                                            </Border>

                                            <TextBlock Grid.Column="1" Text="{x:Bind Name}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextWrapping="Wrap" MaxLines="2"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center" />

                                            <Button Grid.Column="2"
                                                    Style="{StaticResource PremiumPrimaryButtonStyle}"
                                                    Click="Execute_Click" Tag="{x:Bind}"
                                                    VerticalAlignment="Center"
                                                    Padding="12,6" MinHeight="32">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE768;" FontSize="11" />
                                                    <TextBlock Text="Execute" FontSize="12" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>

                                        <!-- Description -->
                                        <TextBlock Text="{x:Bind Description}" FontSize="12"
                                                   TextWrapping="Wrap" MaxLines="3"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                        <!-- Tags -->
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <Border CornerRadius="4" Padding="8,3"
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}">
                                                <TextBlock FontSize="10" FontWeight="SemiBold">
                                                    <Run Text="Risk: " />
                                                    <Run Text="{x:Bind RiskLevel}" />
                                                </TextBlock>
                                            </Border>
                                            <Border CornerRadius="4" Padding="8,3"
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}">
                                                <TextBlock Text="{x:Bind ActionType}" FontSize="10" FontWeight="SemiBold" />
                                            </Border>
                                            <Border CornerRadius="4" Padding="8,3"
                                                    Background="{ThemeResource ControlFillColorTertiaryBrush}">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <FontIcon Glyph="&#xE916;" FontSize="9" VerticalAlignment="Center" />
                                                    <TextBlock FontSize="10" FontWeight="SemiBold">
                                                        <Run Text="~" />
                                                        <Run Text="{x:Bind EstimatedTimeSeconds}" />
                                                        <Run Text="s" />
                                                    </TextBlock>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <Border Height="20" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>