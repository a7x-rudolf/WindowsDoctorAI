<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsDoctorAI.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WindowsDoctorAI.Models"
    xmlns:converters="using:WindowsDoctorAI.Converters"
    NavigationCacheMode="Required">

    <Page.Resources>
        <converters:HealthScoreToColorConverter x:Key="ScoreColor" />
        <converters:CountToVisibilityConverter x:Key="CountToVis" />
        <converters:CountToVisibilityConverter x:Key="CountToInvVis" Invert="True" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <ScrollViewer Padding="32,24" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="8" HorizontalAlignment="Stretch">

            <!-- Header -->
            <Grid Margin="0,0,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Spacing="4">
                    <TextBlock Text="Scan History" Style="{StaticResource PageTitleStyle}" />
                    <TextBlock Text="Review previous diagnostic scans and trends over time"
                               Style="{StaticResource PageSubtitleStyle}" />
                </StackPanel>

                <Button Grid.Column="1" Content="Clear All"
                        Click="ClearAll_Click"
                        VerticalAlignment="Bottom"
                        Visibility="{x:Bind ViewModel.ScanHistory.Count, Mode=OneWay, Converter={StaticResource CountToVis}}" />
            </Grid>

            <!-- Loading -->
            <ProgressRing IsActive="{x:Bind ViewModel.IsHistoryLoading, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.IsHistoryLoading, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                          Width="32" Height="32" HorizontalAlignment="Center" Margin="0,20" />

            <!-- Empty State -->
            <Border Style="{StaticResource PremiumCardStyle}"
                    Visibility="{x:Bind ViewModel.ScanHistory.Count, Mode=OneWay, Converter={StaticResource CountToInvVis}}">
                <StackPanel Spacing="12" Padding="40" HorizontalAlignment="Center">
                    <FontIcon Glyph="&#xE81C;" FontSize="48"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="No Scan History Yet" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                    <TextBlock Text="Run a diagnostic scan and it will show up here automatically"
                               Style="{StaticResource PageSubtitleStyle}"
                               HorizontalAlignment="Center" />
                    <Button Content="Go to Diagnostic Scan"
                            Style="{StaticResource PremiumPrimaryButtonStyle}"
                            HorizontalAlignment="Center" Margin="0,8,0,0"
                            Click="GoToScan_Click" />
                </StackPanel>
            </Border>

            <!-- History List -->
            <ItemsControl x:Name="HistoryList"
                          ItemsSource="{x:Bind ViewModel.ScanHistory, Mode=OneWay}"
                          Visibility="{x:Bind ViewModel.ScanHistory.Count, Mode=OneWay, Converter={StaticResource CountToVis}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:ScanHistoryEntry">
                        <Border Style="{StaticResource PremiumCardStyle}" Margin="0,0,0,10">
                            <Grid Padding="4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <!-- Score badge -->
                                <Border Grid.Column="0" Width="48" Height="48" CornerRadius="24"
                                        Background="{x:Bind OverallScore, Converter={StaticResource ScoreColor}}"
                                        Margin="0,0,16,0" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind ScoreDisplay}" FontSize="16" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>

                                <!-- Info -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind DateDisplay}" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind IssuesSummary}" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock FontSize="11"
                                               Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                        <Run Text="{x:Bind HealthRating}" />
                                        <Run Text=" Â· " />
                                        <Run Text="{x:Bind DurationDisplay}" />
                                        <Run Text="s scan" />
                                    </TextBlock>
                                </StackPanel>

                                <!-- Actions -->
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                            VerticalAlignment="Center">
                                    <Button Content="View" Tag="{x:Bind}" Click="ViewDetail_Click"
                                            Padding="14,6" MinHeight="30" FontSize="12" />
                                    <Button Tag="{x:Bind}" Click="Delete_Click"
                                            Padding="8,6" MinHeight="30"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTipService.ToolTip="Delete this scan">
                                        <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
