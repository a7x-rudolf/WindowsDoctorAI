<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WindowsDoctorAI.Dialogs.RepairProgressDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title=""
    CloseButtonText=""
    PrimaryButtonText=""
    IsPrimaryButtonEnabled="False">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">560</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">520</x:Double>
    </ContentDialog.Resources>

    <StackPanel Width="520" Spacing="16">
        <!-- Header -->
        <StackPanel HorizontalAlignment="Center" Spacing="10">
            <Border x:Name="HeaderIconBorder" Width="64" Height="64" CornerRadius="16"
                    Background="{StaticResource AccentGradientBrush}">
                <FontIcon x:Name="HeaderIcon" Glyph="&#xE90F;" FontSize="28" Foreground="White" />
            </Border>
            <TextBlock x:Name="TitleText" Text="Executing Repair"
                       FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock x:Name="SubtitleText" Text=""
                       FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
        </StackPanel>

        <!-- Progress bar (indeterminate) -->
        <StackPanel Spacing="8">
            <ProgressBar x:Name="ProgressBar" IsIndeterminate="True"
                         MinHeight="6" CornerRadius="3" />
            <TextBlock x:Name="StatusText" Text="Running..."
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Live log -->
        <StackPanel Spacing="6">
            <Grid>
                <TextBlock Text="EXECUTION LOG"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           CharacterSpacing="80"
                           HorizontalAlignment="Left" />
                <StackPanel Orientation="Horizontal" Spacing="4"
                            HorizontalAlignment="Right">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource StatusCriticalBrush}"
                             VerticalAlignment="Center" />
                    <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold"
                               Foreground="{StaticResource StatusCriticalBrush}" />
                </StackPanel>
            </Grid>

            <Border Background="{ThemeResource ControlFillColorTertiaryBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6"
                    Padding="12" MinHeight="160" MaxHeight="240">
                <ScrollViewer x:Name="LogScrollViewer" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="LogPanel" Spacing="4" />
                </ScrollViewer>
            </Border>
        </StackPanel>
    </StackPanel>
</ContentDialog>