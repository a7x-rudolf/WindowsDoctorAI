<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WindowsDoctorAI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Windows Doctor AI">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- MAIN NAVIGATION VIEW -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="260"
            IsPaneToggleButtonVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            Background="Transparent">

            <NavigationView.PaneHeader>
                <StackPanel Padding="16,20,16,12" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <!-- App Logo (Actual Icon) -->
                        <Border Width="36" Height="36" CornerRadius="8">
                            <Image Source="ms-appx:///Assets/AppIcon.png" 
                                   Stretch="UniformToFill" />
                        </Border>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Windows Doctor AI" FontWeight="SemiBold" FontSize="14" />
                            <TextBlock Text="Premium Edition" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.MenuItems>
                <NavigationViewItemHeader Content="Diagnostics" />

                <NavigationViewItem Tag="dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Tag="scan" Content="Diagnostic Scan">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE773;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Tag="results" Content="Scan Results">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9F9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Tag="repair" Content="Repair Actions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE90F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />
                <NavigationViewItemHeader Content="Insights" />

                <NavigationViewItem Tag="history" Content="Scan History">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Tag="system" Content="System Info">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE770;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Tag="settings" Content="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Tag="about" Content="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <NavigationView.PaneFooter>
                <!-- User Panel -->
                <Border Margin="8,4,8,12" Padding="10" CornerRadius="6"
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16"
                                Background="{StaticResource AccentGradientBrush}"
                                Margin="0,0,10,0"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <TextBlock x:Name="UserAvatarText" Text="A"
                                       Foreground="White" FontWeight="SemiBold"
                                       FontSize="14"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="UserNameText" Text="Administrator"
                                       FontSize="13" FontWeight="SemiBold" />
                            <TextBlock x:Name="UserRoleText" Text="Elevated Session"
                                       FontSize="11"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <FontIcon Grid.Column="2" x:Name="UserStatusIcon"
                                  Glyph="&#xE73E;" FontSize="14"
                                  Foreground="{StaticResource StatusHealthyBrush}"
                                  VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- STATUS BAR -->
        <Border Grid.Row="1"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="8" Height="8"
                             Fill="{StaticResource StatusHealthyBrush}" />
                    <TextBlock x:Name="StatusText" Text="System Ready"
                               FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                </StackPanel>

                <ProgressRing x:Name="StatusProgress"
                              Grid.Column="1"
                              Width="14" Height="14"
                              IsActive="False"
                              Margin="16,0,0,0"
                              VerticalAlignment="Center" />

                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="16"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE121;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="LastScanText" Text="Last scan: Never"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7EF;" FontSize="11"
                                  Foreground="{StaticResource StatusHealthyBrush}" />
                        <TextBlock x:Name="AdminStatusText" Text="Administrator"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="4" Text="WinUI 3" Margin="16,0,0,0"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>
    </Grid>
</Window>