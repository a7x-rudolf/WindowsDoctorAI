<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WindowsDoctorAI.Dialogs.ResultDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WindowsDoctorAI.Models"
    xmlns:converters="using:WindowsDoctorAI.Converters"
    Title=""
    CloseButtonText="Close">

    <ContentDialog.Resources>
        <converters:CountToVisibilityConverter x:Key="CountToVis" />
        <converters:StringToVisibilityConverter x:Key="StrToVis" />
        <x:Double x:Key="ContentDialogMaxWidth">640</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="600" Width="580">
        <StackPanel Spacing="16">
            <!-- Header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="HeaderIconBorder" Grid.Column="0"
                        Width="44" Height="44" CornerRadius="8"
                        Margin="0,0,14,0" VerticalAlignment="Top">
                    <FontIcon x:Name="HeaderIcon" FontSize="20" />
                </Border>

                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <TextBlock x:Name="MetaText" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <!-- Description -->
            <StackPanel Spacing="6">
                <TextBlock Text="DESCRIPTION" Style="{StaticResource CaptionUppercaseStyle}" />
                <TextBlock x:Name="DescText" FontSize="13" TextWrapping="Wrap"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            </StackPanel>

            <!-- Details -->
            <StackPanel Spacing="6"
                        Visibility="{x:Bind DetailsText.Text, Mode=OneWay, Converter={StaticResource StrToVis}}">
                <TextBlock Text="TECHNICAL DETAILS" Style="{StaticResource CaptionUppercaseStyle}" />
                <Border Background="{ThemeResource ControlFillColorTertiaryBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1" CornerRadius="6" Padding="12">
                    <TextBlock x:Name="DetailsText" FontSize="12"
                               FontFamily="Cascadia Code, Consolas"
                               TextWrapping="Wrap" />
                </Border>
            </StackPanel>

            <!-- Actions -->
            <StackPanel Spacing="6">
                <Grid>
                    <TextBlock Text="AVAILABLE REPAIR ACTIONS" Style="{StaticResource CaptionUppercaseStyle}"
                               HorizontalAlignment="Left" />
                    <TextBlock x:Name="ActionCountText" Style="{StaticResource CaptionUppercaseStyle}"
                               HorizontalAlignment="Right" />
                </Grid>
                <ItemsControl x:Name="ActionsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:RepairAction">
                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="12"
                                    Margin="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
                                            Background="{StaticResource StatusInfoBgBrush}"
                                            Margin="0,0,12,0">
                                        <FontIcon Glyph="&#xE90F;" FontSize="14"
                                                  Foreground="{StaticResource StatusInfoBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}">
                                            <Run Text="{x:Bind ActionType}" />
                                            <Run Text=" - Risk: " />
                                            <Run Text="{x:Bind RiskLevel}" />
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="2" Content="Execute"
                                            Tag="{x:Bind}"
                                            Click="ExecuteAction_Click"
                                            Style="{StaticResource PremiumPrimaryButtonStyle}"
                                            Padding="14,6" MinHeight="30"
                                            FontSize="12" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <!-- No actions -->
            <Border x:Name="NoActionsHint"
                    Background="{StaticResource StatusHealthyBgBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="6" Padding="12">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE73E;" FontSize="16"
                              Foreground="{StaticResource StatusHealthyBrush}" />
                    <TextBlock Text="No repair actions needed - this item is healthy."
                               VerticalAlignment="Center" FontSize="13"
                               Foreground="{StaticResource StatusHealthyBrush}" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>