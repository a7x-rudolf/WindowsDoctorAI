<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsDoctorAI.Views.DiagnosticPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WindowsDoctorAI.Converters"
    xmlns:models="using:WindowsDoctorAI.Models"
    NavigationCacheMode="Required">

    <Page.Resources>
        <converters:SeverityToColorConverter x:Key="SevColor" />
        <converters:SeverityToBackgroundConverter x:Key="SevBg" />
        <converters:SeverityToGlyphConverter x:Key="SevGlyph" />
        <converters:SeverityToStringConverter x:Key="SevString" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </Page.Resources>

    <ScrollViewer Padding="32,24" HorizontalScrollBarVisibility="Disabled">
        <Grid HorizontalAlignment="Stretch">
            <StackPanel Spacing="8" HorizontalAlignment="Stretch" MaxWidth="1600">

                <!-- Page Header -->
                <TextBlock Text="Diagnostic Scan" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Configure and run comprehensive system diagnostics"
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0,0,0,20" />

                <!-- Scan Configuration Card -->
                <Border Style="{StaticResource PremiumCardStyle}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Select Scan Categories" Style="{StaticResource CardTitleStyle}" />
                        <TextBlock Text="Choose which categories to analyze. Full scan (all checked) is recommended for accurate diagnosis."
                                   FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   TextWrapping="Wrap" />


                        <!-- Categories Grid (manual - proportional) -->
                        <Grid ColumnSpacing="8" RowSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" MinWidth="280" />
                                <ColumnDefinition Width="*" MinWidth="280" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Disk Health -->
                            <Border Grid.Row="0" Grid.Column="0"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,10,0" MinWidth="20" />
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="6"
                                            Background="{StaticResource StatusInfoBgBrush}" Margin="0,0,10,0">
                                        <FontIcon Glyph="&#xEDA2;" FontSize="14"
                                                  Foreground="{StaticResource StatusInfoBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Disk Health" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Space, SMART, temp files" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Performance -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,10,0" MinWidth="20" />
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="6"
                                            Background="{StaticResource StatusInfoBgBrush}" Margin="0,0,10,0">
                                        <FontIcon Glyph="&#xE945;" FontSize="14"
                                                  Foreground="{StaticResource StatusInfoBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Performance" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="CPU, RAM, processes" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Network -->
                            <Border Grid.Row="1" Grid.Column="0"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,10,0" MinWidth="20" />
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="6"
                                            Background="{StaticResource StatusInfoBgBrush}" Margin="0,0,10,0">
                                        <FontIcon Glyph="&#xE968;" FontSize="14"
                                                  Foreground="{StaticResource StatusInfoBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Network" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Connectivity, DNS, latency" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Security -->
                            <Border Grid.Row="1" Grid.Column="1"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,10,0" MinWidth="20" />
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="6"
                                            Background="{StaticResource StatusInfoBgBrush}" Margin="0,0,10,0">
                                        <FontIcon Glyph="&#xE72E;" FontSize="14"
                                                  Foreground="{StaticResource StatusInfoBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Security" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Antivirus, firewall, UAC" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Windows Update -->
                            <Border Grid.Row="2" Grid.Column="0"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,10,0" MinWidth="20" />
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="6"
                                            Background="{StaticResource StatusInfoBgBrush}" Margin="0,0,10,0">
                                        <FontIcon Glyph="&#xE895;" FontSize="14"
                                                  Foreground="{StaticResource StatusInfoBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Windows Update" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Service, updates, reboot" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <!-- Startup -->
                            <Border Grid.Row="2" Grid.Column="1"
                                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="14,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox Grid.Column="0" IsChecked="True" Margin="0,0,10,0" MinWidth="20" />
                                    <Border Grid.Column="1" Width="32" Height="32" CornerRadius="6"
                                            Background="{StaticResource StatusInfoBgBrush}" Margin="0,0,10,0">
                                        <FontIcon Glyph="&#xE7C1;" FontSize="14"
                                                  Foreground="{StaticResource StatusInfoBrush}" />
                                    </Border>
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Startup Programs" FontSize="13" FontWeight="SemiBold" />
                                        <TextBlock Text="Registry, scheduled tasks" FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>

                        <!-- Action row -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource PremiumPrimaryButtonStyle}"
                                    Click="Start_Click"
                                    IsEnabled="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource InverseBool}}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE768;" FontSize="14" />
                                    <TextBlock Text="Start Diagnostic Scan" />
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="1"
                                    Style="{StaticResource PremiumButtonStyle}"
                                    Margin="8,0,0,0"
                                    Click="Cancel_Click"
                                    Visibility="{x:Bind ViewModel.IsScanning, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE711;" FontSize="14" />
                                    <TextBlock Text="Cancel" />
                                </StackPanel>
                            </Button>

                            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="6"
                                        VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE916;" FontSize="11"
                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                <TextBlock Text="Estimated duration: ~45 seconds"
                                           FontSize="12"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Height="20" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>