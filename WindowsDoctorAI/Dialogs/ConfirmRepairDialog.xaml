<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WindowsDoctorAI.Dialogs.ConfirmRepairDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title=""
    PrimaryButtonText="Execute Repair"
    CloseButtonText="Cancel"
    DefaultButton="Close">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">520</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">480</x:Double>
    </ContentDialog.Resources>

    <StackPanel Width="480" Spacing="16">
        <!-- Header -->
        <StackPanel HorizontalAlignment="Center" Spacing="12">
            <Border Width="64" Height="64" CornerRadius="32"
                    Background="{StaticResource StatusWarningBgBrush}">
                <FontIcon Glyph="&#xE7BA;" FontSize="28"
                          Foreground="{StaticResource StatusWarningBrush}" />
            </Border>
            <TextBlock Text="Confirm Repair Action"
                       FontSize="20" FontWeight="Bold"
                       HorizontalAlignment="Center" />
            <TextBlock Text="Please review the details before executing"
                       FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <!-- Action Name -->
        <StackPanel Spacing="4">
            <TextBlock x:Name="ActionNameText" FontSize="15" FontWeight="SemiBold" />
            <TextBlock x:Name="ActionDescText" FontSize="13"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- Details table -->
        <Border Background="{ThemeResource ControlFillColorTertiaryBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="6" Padding="16,4">
            <StackPanel>
                <Grid Padding="0,10" BorderThickness="0,0,0,1"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE945;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Action Type" FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="ActionTypeText" Grid.Column="1" FontSize="13" FontWeight="SemiBold" />
                </Grid>

                <Grid Padding="0,10" BorderThickness="0,0,0,1"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7BA;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Risk Level" FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="RiskLevelText" Grid.Column="1" FontSize="13" FontWeight="SemiBold" />
                </Grid>

                <Grid Padding="0,10" BorderThickness="0,0,0,1"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE916;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Estimated Time" FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="EstTimeText" Grid.Column="1" FontSize="13" FontWeight="SemiBold" />
                </Grid>

                <Grid Padding="0,10" BorderThickness="0,0,0,1"
                      BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7EF;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Requires Admin" FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="AdminText" Grid.Column="1" FontSize="13" FontWeight="SemiBold" />
                </Grid>

                <Grid Padding="0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE777;" FontSize="11"
                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="Requires Reboot" FontSize="13"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <TextBlock x:Name="RebootText" Grid.Column="1" FontSize="13" FontWeight="SemiBold" />
                </Grid>
            </StackPanel>
        </Border>

        <!-- Info callout -->
        <InfoBar x:Name="InfoCallout" IsOpen="True" IsClosable="False" Severity="Informational"
                 Title="Safe Action"
                 Message="This action is generally safe and reversible." />
    </StackPanel>
</ContentDialog>