<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsDoctorAI.Views.AboutPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="32,24">
        <Grid HorizontalAlignment="Stretch">
            <StackPanel Spacing="8" HorizontalAlignment="Left" MaxWidth="1400">

                <TextBlock Text="About" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Learn more about WindowsDoctorAI"
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0,0,0,20" />

                <!-- 2-column layout: Hero left, Info right -->
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Left: App Hero -->
                    <Border Grid.Column="0" Style="{StaticResource HeroCardStyle}"
                            VerticalAlignment="Top">
                        <StackPanel HorizontalAlignment="Center" Spacing="12">
                            <!-- App Logo/Icon -->
                            <Border Width="120" Height="120" CornerRadius="24"
                                    HorizontalAlignment="Center"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <Image Source="ms-appx:///Assets/AppIcon.png" 
                                       Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Text="WindowsDoctorAI"
                                       FontSize="22" FontWeight="Bold"
                                       HorizontalAlignment="Center" />
                            <TextBlock Text="Version 2.0.1"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />
                            <Border Padding="10,4" CornerRadius="10"
                                    Background="{StaticResource StatusInfoBgBrush}"
                                    HorizontalAlignment="Center">
                                <TextBlock Text="Premium Edition" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource StatusInfoBrush}" />
                            </Border>
                            <TextBlock Text="Version 2.0.1 - Premium Edition"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       HorizontalAlignment="Center" />

                            <Border Padding="10,4" CornerRadius="10"
                                    Background="{StaticResource StatusInfoBgBrush}"
                                    HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock Text="Developed by Ridolf Widi AlfISA Lumba" 
                                           FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource StatusInfoBrush}" />
                            </Border>

                            <TextBlock Text="© 2025 Ridolf Widi Alfisa Lumba. All Rights Reserved."
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                       Margin="0,8,0,0" />

                            <TextBlock Text="Licensed under MIT License"
                                       FontSize="10"
                                       HorizontalAlignment="Center"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </Border>

                    <!-- Right: Info Cards Grid -->
                    <StackPanel Grid.Column="1" Spacing="12">

                        <!-- Features -->
                        <Border Style="{StaticResource PremiumCardStyle}">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE762;" FontSize="14"
                                              Foreground="{StaticResource BrandAccentBrush}" />
                                    <TextBlock Text="Diagnostic Categories" FontWeight="SemiBold" FontSize="14" />
                                </StackPanel>
                                <Grid ColumnSpacing="20" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xEDA2;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="Disk Health" FontSize="13" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE945;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="Performance" FontSize="13" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE968;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="Network" FontSize="13" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE72E;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="Security" FontSize="13" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE895;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="Windows Update" FontSize="13" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE770;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="Drivers" FontSize="13" />
                                    </StackPanel>
                                    <StackPanel Grid.Row="3" Grid.Column="0" Orientation="Horizontal" Spacing="8">
                                        <FontIcon Glyph="&#xE7C1;" FontSize="12"
                                                  Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        <TextBlock Text="Startup Programs" FontSize="13" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Tech Stack -->
                        <Border Style="{StaticResource PremiumCardStyle}">
                            <StackPanel Spacing="10">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE950;" FontSize="14"
                                              Foreground="{StaticResource BrandAccentBrush}" />
                                    <TextBlock Text="Technology Stack" FontWeight="SemiBold" FontSize="14" />
                                </StackPanel>
                                <Grid ColumnSpacing="20" RowSpacing="6">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text=".NET 8.0" FontSize="13" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="WinUI 3 - Windows App SDK 1.5" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="C# 12" FontSize="13" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="CommunityToolkit.Mvvm 8.2.2" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Visual Studio 2022 Community" FontSize="13" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Segoe Fluent Icons" FontSize="13" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Notice -->
                        <InfoBar IsOpen="True" IsClosable="False" Severity="Informational"
                                 Title="Administrator Access Required"
                                 Message="Full diagnostic capabilities require administrator privileges. Run as administrator for accurate results." />
                    </StackPanel>
                </Grid>

                <Border Height="20" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>