<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="WindowsDoctorAI.Dialogs.HistoryDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:WindowsDoctorAI.Models"
    xmlns:converters="using:WindowsDoctorAI.Converters"
    Title=""
    CloseButtonText="Close">

    <ContentDialog.Resources>
        <converters:SeverityToColorConverter x:Key="SevColor" />
        <converters:SeverityToBackgroundConverter x:Key="SevBg" />
        <converters:SeverityToGlyphConverter x:Key="SevGlyph" />
        <x:Double x:Key="ContentDialogMaxWidth">640</x:Double>
        <x:Double x:Key="ContentDialogMinWidth">560</x:Double>
    </ContentDialog.Resources>

    <ScrollViewer MaxHeight="600" Width="580">
        <StackPanel Spacing="16">
            <!-- Header -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border x:Name="ScoreBadge" Grid.Column="0"
                        Width="52" Height="52" CornerRadius="26"
                        Margin="0,0,14,0" VerticalAlignment="Top">
                    <TextBlock x:Name="ScoreText" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Foreground="White" />
                </Border>

                <StackPanel Grid.Column="1" Spacing="2">
                    <TextBlock x:Name="TitleText" FontSize="18" FontWeight="Bold" TextWrapping="Wrap" />
                    <TextBlock x:Name="MetaText" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
            </Grid>

            <!-- Results grouped by severity -->
            <StackPanel Spacing="6">
                <TextBlock Text="DIAGNOSTIC RESULTS" Style="{StaticResource CaptionUppercaseStyle}" />
                <ItemsControl x:Name="ResultsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:ScanHistoryResult">
                            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="6" Padding="12"
                                    Margin="0,3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="32" Height="32" CornerRadius="6"
                                            Background="{x:Bind Severity, Converter={StaticResource SevBg}}"
                                            Margin="0,0,12,0">
                                        <FontIcon Glyph="{x:Bind Severity, Converter={StaticResource SevGlyph}}"
                                                  FontSize="14"
                                                  Foreground="{x:Bind Severity, Converter={StaticResource SevColor}}" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Title}" FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap">
                                            <Run Text="{x:Bind CategoryDisplayName}" />
                                            <Run Text=" â€” " />
                                            <Run Text="{x:Bind Description}" />
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
