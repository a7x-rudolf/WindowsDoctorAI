<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="WindowsDoctorAI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Windows Doctor AI">

    <Grid x:Name="RootGrid" Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- NAVIGATION VIEW (Compact Sidebar) -->
        <!-- ════════════════════════════════════════════════════════ -->
        <NavigationView
            x:Name="NavView"
            Grid.Row="0"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            OpenPaneLength="220"
            IsPaneToggleButtonVisible="False"
            SelectionChanged="NavView_SelectionChanged"
            Background="Transparent">

            <!-- Sidebar Header: App Logo + Brand -->
            <NavigationView.PaneHeader>
                <StackPanel Padding="14,16,14,10" Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="32" Height="32" CornerRadius="8">
                            <Image Source="ms-appx:///Assets/AppIcon.png" 
                                   Stretch="UniformToFill" />
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Windows Doctor AI" 
                                       FontWeight="Bold" FontSize="13" />
                            <TextBlock Text="v2.0.1 Premium" FontSize="10"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneHeader>

            <!-- Navigation Menu Items -->
            <NavigationView.MenuItems>
                <NavigationViewItemHeader x:Name="HeaderDiagnostics" Content="DIAGNOSTICS" />

                <NavigationViewItem x:Name="NavDashboard" Tag="dashboard" Content="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" FontSize="15" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavScan" Tag="scan" Content="Diagnostic Scan">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE773;" FontSize="15" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavResults" Tag="results" Content="Scan Results">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9F9;" FontSize="15" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavRepair" Tag="repair" Content="Repair Actions">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE90F;" FontSize="15" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />
                <NavigationViewItemHeader x:Name="HeaderInsights" Content="INSIGHTS" />

                <NavigationViewItem x:Name="NavHistory" Tag="history" Content="Scan History">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;" FontSize="15" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem x:Name="NavSystem" Tag="system" Content="System Info">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE770;" FontSize="15" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <!-- Footer Menu Items -->
            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="NavSettings" Tag="settings" Content="Settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" FontSize="15" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="NavAbout" Tag="about" Content="About">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE946;" FontSize="15" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <!-- User Panel (Bottom of Sidebar) -->
            <NavigationView.PaneFooter>
                <Border Margin="8,4,8,10" Padding="8" CornerRadius="8"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15"
                                Background="{StaticResource AccentGradientBrush}"
                                Margin="0,0,8,0">
                            <TextBlock x:Name="UserAvatarText" Text="R"
                                       Foreground="White" FontWeight="Bold"
                                       FontSize="12"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center" />
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock x:Name="UserNameText" Text="RIDOLF"
                                       FontSize="12" FontWeight="SemiBold" />
                            <TextBlock x:Name="UserRoleText" Text="Administrator"
                                       FontSize="10"
                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        </StackPanel>

                        <Ellipse Grid.Column="2" Width="8" Height="8"
                                 x:Name="UserStatusIcon"
                                 Fill="{StaticResource StatusHealthyBrush}"
                                 VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </NavigationView.PaneFooter>

            <Frame x:Name="ContentFrame" />
        </NavigationView>

        <!-- ════════════════════════════════════════════════════════ -->
        <!-- STATUS BAR (Bottom) -->
        <!-- ════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1"
                Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Status dot + text -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center">
                    <Ellipse x:Name="StatusDot" Width="6" Height="6"
                             Fill="{StaticResource StatusHealthyBrush}" />
                    <TextBlock x:Name="StatusText" Text="System Ready"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <!-- Progress ring -->
                <ProgressRing x:Name="StatusProgress"
                              Grid.Column="1"
                              Width="12" Height="12"
                              IsActive="False"
                              Margin="12,0,0,0" />

                <!-- Right info -->
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="4">
                        <FontIcon Glyph="&#xE121;" FontSize="10"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                        <TextBlock x:Name="LastScanText" Text="Last scan: Never"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                    </StackPanel>

                    <TextBlock Text="·" FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                    <TextBlock x:Name="AdminStatusText" Text="Administrator"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                    <TextBlock Text="·" FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />

                    <TextBlock Text="WinUI 3" FontSize="11"
                               Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                </StackPanel>

                <!-- ════════════════════════════════════════════════ -->
                <!-- LANGUAGE + THEME TOGGLES -->
                <!-- ════════════════════════════════════════════════ -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8"
                            VerticalAlignment="Center" Margin="16,0,0,0">

                    <!-- Language toggle (EN / ID) -->
                    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1" CornerRadius="4" Padding="2">
                        <StackPanel Orientation="Horizontal" Spacing="2">
                            <Button x:Name="LangEnButton" Content="EN"
                                    FontSize="10" Padding="8,3" MinWidth="0"
                                    CornerRadius="3"
                                    Click="LangEnButton_Click" />
                            <Button x:Name="LangIdButton" Content="ID"
                                    FontSize="10" Padding="8,3" MinWidth="0"
                                    CornerRadius="3"
                                    Click="LangIdButton_Click" />
                        </StackPanel>
                    </Border>

                    <!-- Theme toggle (Light / Dark) -->
                    <Button x:Name="ThemeToggleButton"
                            Padding="8,3" CornerRadius="4"
                            Click="ThemeToggleButton_Click">
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <FontIcon x:Name="ThemeToggleIcon" Glyph="&#xE706;" FontSize="12" />
                            <TextBlock x:Name="ThemeToggleLabel" Text="Light" FontSize="11" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>