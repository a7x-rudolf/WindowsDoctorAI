<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- BRAND COLORS v2.0.1 - Blue Accent (synced with app icon) -->
    <!-- ════════════════════════════════════════════════════════ -->

    <!-- Brand Accent (Blue - matching icon) -->
    <SolidColorBrush x:Key="BrandAccentBrush" Color="#1a8fc4" />
    <SolidColorBrush x:Key="BrandAccentSecondaryBrush" Color="#1578a7" />
    <SolidColorBrush x:Key="BrandAccentTertiaryBrush" Color="#4CC2FF" />
    <SolidColorBrush x:Key="BrandAccentBgBrush" Color="#1A1a8fc4" />

    <!-- Status Colors (Universal - tidak berubah) -->
    <SolidColorBrush x:Key="StatusHealthyBrush" Color="#2ecc71" />
    <SolidColorBrush x:Key="StatusHealthyBgBrush" Color="#142ecc71" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#e67e22" />
    <SolidColorBrush x:Key="StatusWarningBgBrush" Color="#14e67e22" />
    <SolidColorBrush x:Key="StatusCriticalBrush" Color="#e74c3c" />
    <SolidColorBrush x:Key="StatusCriticalBgBrush" Color="#14e74c3c" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#3498db" />
    <SolidColorBrush x:Key="StatusInfoBgBrush" Color="#143498db" />

    <!-- Card Hover Border -->
    <SolidColorBrush x:Key="CardHoverBorderBrush" Color="#4C1a8fc4" />

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- GRADIENTS -->
    <!-- ════════════════════════════════════════════════════════ -->

    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0a1628" Offset="0" />
        <GradientStop Color="#1a8fc4" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HealthyGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#2ecc71" Offset="0" />
        <GradientStop Color="#27ae60" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WarningGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#e67e22" Offset="0" />
        <GradientStop Color="#d35400" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CriticalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#e74c3c" Offset="0" />
        <GradientStop Color="#c0392b" Offset="1" />
    </LinearGradientBrush>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- TYPOGRAPHY -->
    <!-- ════════════════════════════════════════════════════════ -->

    <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="20" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="26" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="CharacterSpacing" Value="60" />
        <Setter Property="Margin" Value="0,16,0,10" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="CaptionUppercaseStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="CharacterSpacing" Value="80" />
    </Style>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- CARD STYLES -->
    <!-- ════════════════════════════════════════════════════════ -->

    <Style x:Key="PremiumCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style x:Key="HeroCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="14" />
        <Setter Property="Padding" Value="24" />
    </Style>

    <Style x:Key="InteractiveCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="14" />
    </Style>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- BUTTON STYLES -->
    <!-- ════════════════════════════════════════════════════════ -->

    <Style x:Key="PremiumPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="MinHeight" Value="40" />
    </Style>

    <Style x:Key="PremiumButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="MinHeight" Value="40" />
    </Style>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- ICON CONTAINER -->
    <!-- ════════════════════════════════════════════════════════ -->

    <Style x:Key="IconContainerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="36" />
    </Style>

    <Style x:Key="LargeIconContainerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
    </Style>

    <!-- ════════════════════════════════════════════════════════ -->
    <!-- EMPTY STATE -->
    <!-- ════════════════════════════════════════════════════════ -->

    <Style x:Key="EmptyStateIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="18" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="400" />
    </Style>

</ResourceDictionary>