<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ BRAND BRUSHES ============ -->
    <SolidColorBrush x:Key="BrandAccentBrush" Color="#0067C0" />
    <SolidColorBrush x:Key="BrandAccentSecondaryBrush" Color="#005BA1" />
    <SolidColorBrush x:Key="BrandAccentTertiaryBrush" Color="#4CC2FF" />

    <SolidColorBrush x:Key="StatusHealthyBrush" Color="#0F7B0F" />
    <SolidColorBrush x:Key="StatusHealthyBgBrush" Color="#140F7B0F" />
    <SolidColorBrush x:Key="StatusWarningBrush" Color="#B7710D" />
    <SolidColorBrush x:Key="StatusWarningBgBrush" Color="#14B7710D" />
    <SolidColorBrush x:Key="StatusCriticalBrush" Color="#C42B1C" />
    <SolidColorBrush x:Key="StatusCriticalBgBrush" Color="#14C42B1C" />
    <SolidColorBrush x:Key="StatusInfoBrush" Color="#005FB8" />
    <SolidColorBrush x:Key="StatusInfoBgBrush" Color="#14005FB8" />

    <!-- Card hover accent -->
    <SolidColorBrush x:Key="CardHoverBorderBrush" Color="#4C0067C0" />

    <!-- ============ GRADIENTS ============ -->
    <LinearGradientBrush x:Key="AccentGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0067C0" Offset="0" />
        <GradientStop Color="#4CC2FF" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HealthyGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#0F7B0F" Offset="0" />
        <GradientStop Color="#2BA82B" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="WarningGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#B7710D" Offset="0" />
        <GradientStop Color="#8F5709" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CriticalGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#C42B1C" Offset="0" />
        <GradientStop Color="#8F1E15" Offset="1" />
    </LinearGradientBrush>

    <!-- ============ TYPOGRAPHY ============ -->
    <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="32" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="LineHeight" Value="36" />
    </Style>

    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="28" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="PageSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>

    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Margin" Value="0,20,0,12" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="CaptionUppercaseStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="CharacterSpacing" Value="80" />
    </Style>

    <!-- ============ CARD STYLES ============ -->
    <Style x:Key="PremiumCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="20" />
    </Style>

    <Style x:Key="HeroCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="12" />
        <Setter Property="Padding" Value="32" />
    </Style>

    <!-- Interactive card with hover effect -->
    <Style x:Key="InteractiveCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource LayerFillColorDefaultBrush}" />
        <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <!-- ============ BUTTON STYLES ============ -->
    <Style x:Key="PremiumPrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource AccentButtonStyle}">
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <Style x:Key="PremiumButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Padding" Value="20,10" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="CornerRadius" Value="4" />
        <Setter Property="MinHeight" Value="36" />
    </Style>

    <!-- ============ PILL / BADGE ============ -->
    <Style x:Key="StatusPillStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="100" />
        <Setter Property="Padding" Value="10,4" />
    </Style>

    <!-- ============ ICON CONTAINER ============ -->
    <Style x:Key="IconContainerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="Width" Value="32" />
        <Setter Property="Height" Value="32" />
    </Style>

    <Style x:Key="LargeIconContainerStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="8" />
        <Setter Property="Width" Value="44" />
        <Setter Property="Height" Value="44" />
    </Style>

    <!-- ============ EMPTY STATE ============ -->
    <Style x:Key="EmptyStateContainerStyle" TargetType="StackPanel">
        <Setter Property="Spacing" Value="12" />
        <Setter Property="Padding" Value="40" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateIconStyle" TargetType="FontIcon">
        <Setter Property="FontSize" Value="48" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style x:Key="EmptyStateTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>

    <Style x:Key="EmptyStateSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="TextWrapping" Value="Wrap" />
        <Setter Property="MaxWidth" Value="360" />
    </Style>

</ResourceDictionary>