<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsDoctorAI.Views.SystemInfoPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    NavigationCacheMode="Required">

    <ScrollViewer Padding="32,24">
        <StackPanel MaxWidth="1000" Spacing="8">
            <TextBlock Text="System Information" Style="{StaticResource PageTitleStyle}" />
            <TextBlock Text="Hardware and software details of your Windows system"
                       Style="{StaticResource PageSubtitleStyle}"
                       Margin="0,0,0,24" />

            <Border Style="{StaticResource PremiumCardStyle}">
                <ItemsRepeater x:Name="SysInfoRepeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Spacing="0" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <Grid Padding="8,12"
                                  BorderThickness="0,0,0,1"
                                  BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="220" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Key}"
                                           FontWeight="SemiBold"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                <TextBlock Grid.Column="1" Text="{Binding Value}"
                                           TextWrapping="Wrap"
                                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Grid>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>