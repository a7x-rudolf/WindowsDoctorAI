<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WindowsDoctorAI.Views.ResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:WindowsDoctorAI.Converters"
    xmlns:models="using:WindowsDoctorAI.Models"
    NavigationCacheMode="Required">

    <Page.Resources>
        <converters:SeverityToColorConverter x:Key="SevColor" />
        <converters:SeverityToBackgroundConverter x:Key="SevBg" />
        <converters:SeverityToGlyphConverter x:Key="SevGlyph" />
        <converters:SeverityToStringConverter x:Key="SevString" />
        <converters:CategoryToGlyphConverter x:Key="CatGlyph" />
        <converters:BoolToVisibilityConverter x:Key="BoolToVis" />
        <converters:CountToVisibilityConverter x:Key="CountToVis" />
        <converters:CountToVisibilityConverter x:Key="CountToInvVis" Invert="True" />
    </Page.Resources>

    <ScrollViewer Padding="32,24" HorizontalScrollBarVisibility="Disabled">
        <Grid HorizontalAlignment="Stretch">
            <StackPanel MaxWidth="1600" Spacing="8" HorizontalAlignment="Left">

                <!-- Header -->
                <TextBlock Text="Scan Results" Style="{StaticResource PageTitleStyle}" />
                <TextBlock Text="Review all diagnostic findings from the last scan"
                           Style="{StaticResource PageSubtitleStyle}"
                           Margin="0,0,0,20" />

                <!-- Empty State -->
                <Border Style="{StaticResource PremiumCardStyle}"
                        Visibility="{x:Bind ViewModel.AllResults.Count, Mode=OneWay, Converter={StaticResource CountToInvVis}}">
                    <StackPanel Spacing="12" Padding="40" HorizontalAlignment="Center">
                        <FontIcon Glyph="&#xE9F9;" FontSize="48"
                                  Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                  HorizontalAlignment="Center" />
                        <TextBlock Text="No Scan Results Yet" FontSize="16" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,8,0,0" />
                        <TextBlock Text="Run a diagnostic scan to see results here"
                                   Style="{StaticResource PageSubtitleStyle}"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>

                <!-- Results Content -->
                <StackPanel Spacing="8"
                            Visibility="{x:Bind ViewModel.AllResults.Count, Mode=OneWay, Converter={StaticResource CountToVis}}">

                    <!-- Filter Toolbar -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Segmented filter -->
                        <Border Grid.Column="0"
                                Background="{ThemeResource ControlFillColorTertiaryBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="10" Padding="3"
                                HorizontalAlignment="Left">
                            <StackPanel Orientation="Horizontal" Spacing="2">
                                <Button x:Name="FilterAllBtn" Content="All"
                                        Click="Filter_Click" Tag="All"
                                        Padding="16,6" CornerRadius="10" MinHeight="32"
                                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderThickness="0"
                                        FontWeight="SemiBold" FontSize="12" />
                                <Button x:Name="FilterCriticalBtn" Content="Critical"
                                        Click="Filter_Click" Tag="Critical"
                                        Padding="16,6" CornerRadius="10" MinHeight="32"
                                        Background="Transparent" BorderThickness="0" FontSize="12" />
                                <Button x:Name="FilterWarningBtn" Content="Warning"
                                        Click="Filter_Click" Tag="Warning"
                                        Padding="16,6" CornerRadius="10" MinHeight="32"
                                        Background="Transparent" BorderThickness="0" FontSize="12" />
                                <Button x:Name="FilterHealthyBtn" Content="Healthy"
                                        Click="Filter_Click" Tag="Healthy"
                                        Padding="16,6" CornerRadius="10" MinHeight="32"
                                        Background="Transparent" BorderThickness="0" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <!-- Right actions -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <TextBlock x:Name="CountText" Text="0 results"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Margin="0,0,8,0" />
                            <Button Click="Export_Click"
                                    Style="{StaticResource PremiumButtonStyle}"
                                    Padding="14,6" MinHeight="32">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE8A5;" FontSize="12" />
                                    <TextBlock Text="Export" FontSize="12" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Results Grid (Responsive UniformGridLayout) -->
                    <ItemsRepeater x:Name="ResultsList">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="380" MinItemHeight="140"
                                               MinColumnSpacing="10" MinRowSpacing="10" />
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:DiagnosticResult">
                                <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="16"
                                        Tag="{x:Bind}"
                                        PointerReleased="ResultItem_Click">
                                    <StackPanel Spacing="10">
                                        <!-- Top: icon + badge -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0" Width="36" Height="36" CornerRadius="6"
                                                    Background="{x:Bind Severity, Converter={StaticResource SevBg}}"
                                                    Margin="0,0,10,0">
                                                <FontIcon Glyph="{x:Bind Severity, Converter={StaticResource SevGlyph}}"
                                                          FontSize="16"
                                                          Foreground="{x:Bind Severity, Converter={StaticResource SevColor}}" />
                                            </Border>

                                            <!-- Score -->
                                            <TextBlock Grid.Column="1" Text="{x:Bind Score}"
                                                       FontSize="24" FontWeight="Bold"
                                                       Foreground="{x:Bind Severity, Converter={StaticResource SevColor}}"
                                                       VerticalAlignment="Center" />

                                            <!-- Severity badge -->
                                            <Border Grid.Column="2"
                                                    Background="{x:Bind Severity, Converter={StaticResource SevColor}}"
                                                    CornerRadius="4" Padding="8,3"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Severity, Converter={StaticResource SevString}}"
                                                           Foreground="White" FontSize="10" FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>

                                        <!-- Title -->
                                        <TextBlock Text="{x:Bind Title}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   TextWrapping="Wrap" MaxLines="2"
                                                   TextTrimming="CharacterEllipsis" />

                                        <!-- Description -->
                                        <TextBlock Text="{x:Bind Description}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" MaxLines="2"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                                        <!-- Meta info -->
                                        <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                            <StackPanel Orientation="Horizontal" Spacing="4">
                                                <FontIcon Glyph="{x:Bind Category, Converter={StaticResource CatGlyph}}"
                                                          FontSize="10"
                                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock Text="{x:Bind CategoryDisplayName}"
                                                           FontSize="10"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Spacing="4"
                                                        Visibility="{x:Bind AvailableActions.Count, Converter={StaticResource CountToVis}}">
                                                <FontIcon Glyph="&#xE90F;" FontSize="10"
                                                          Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                                <TextBlock FontSize="10"
                                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                                    <Run Text="{x:Bind AvailableActions.Count}" />
                                                    <Run Text=" action(s)" />
                                                </TextBlock>
                                            </StackPanel>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <Border Height="20" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Page>